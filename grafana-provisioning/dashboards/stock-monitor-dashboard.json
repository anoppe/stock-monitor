          "query": "data = from(bucket: \"stocks\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"fund_performance\")\n  |> filter(fn: (r) => r._field == \"nav\")\n  |> sort(columns: [\"_time\"])\n\nfirst_value = data |> first() |> findRecord(fn: (key) => true, idx: 0)\nlast_value = data |> last() |> findRecord(fn: (key) => true, idx: 0)\n\nyield = (last_value._value - first_value._value) / first_value._value * 100.0\n\nfrom(bucket: \"stocks\")\n  |> range(start: 0)\n  |> filter(fn: (r) => false)\n  |> map(fn: (r) => ({_time: now(), _value: yield, _field: \"30d_return\"}))",
          "refId": "A"
        }
      ],
      "title": "30-Day Return %",
      "type": "stat"
